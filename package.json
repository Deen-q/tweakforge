{
  "name": "tweakforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run generate-scripts && npm run generate-versiondata && next dev --turbopack",
    "build": "npm run generate-scripts && npm run generate-versiondata && next build",
    "start": "next start",
    "lint": "next lint",
